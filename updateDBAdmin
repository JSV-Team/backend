CREATE VIEW vw_AdminActivityList
AS
SELECT
    a.activity_id,
    a.creator_id,
    u.username AS creator_username,
    u.full_name AS creator_full_name,
    u.avatar_url AS creator_avatar_url,
    a.title,
    a.description,
    a.location,
    a.duration_minutes,
    a.max_participants,
    a.status,
    a.created_at,
    a.reviewed_by,
    a.reviewed_at,
    a.deleted_by,
    a.deleted_at,
    (
        SELECT COUNT(*)
        FROM Reports r
        WHERE r.reported_activity_id = a.activity_id
    ) AS report_count,
    (
        SELECT TOP 1 ai.image_url
        FROM ActivityImages ai
        WHERE ai.activity_id = a.activity_id
        ORDER BY ai.is_thumbnail DESC, ai.sort_order ASC, ai.image_id ASC
    ) AS thumbnail_url
FROM Activities a
JOIN Users u ON u.user_id = a.creator_id;
GO


