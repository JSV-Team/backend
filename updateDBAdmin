CREATE PROCEDURE sp_AdminDashboardSummary
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        (SELECT COUNT(*) FROM Users) AS total_users,
        (SELECT COUNT(*) FROM Activities) AS total_activities,
        (SELECT COUNT(*) FROM Reports WHERE status = 'pending') AS pending_reports,
        (SELECT COUNT(*) FROM MatchSessions WHERE status = 'active') AS active_matches;
END
GO


/* =====================================================
   17. PROC HỖ TRỢ CHART THỐNG KÊ USER/ACTIVITY THEO THÁNG
   ===================================================== */
IF OBJECT_ID('sp_AdminStatisticsMonthlyGrowth', 'P') IS NOT NULL
BEGIN
    DROP PROCEDURE sp_AdminStatisticsMonthlyGrowth;
END
GO

CREATE PROCEDURE sp_AdminStatisticsMonthlyGrowth
AS
BEGIN
    SET NOCOUNT ON;

    ;WITH Months AS (
        SELECT 1 AS month_num UNION ALL
        SELECT 2 UNION ALL
        SELECT 3 UNION ALL
        SELECT 4 UNION ALL
        SELECT 5 UNION ALL
        SELECT 6 UNION ALL
        SELECT 7 UNION ALL
        SELECT 8 UNION ALL
        SELECT 9 UNION ALL
        SELECT 10 UNION ALL
        SELECT 11 UNION ALL
        SELECT 12
    )
    SELECT
        m.month_num,
        CONCAT('T', m.month_num) AS month_label,
        ISNULL(u.user_count, 0) AS user_count,
        ISNULL(a.activity_count, 0) AS activity_count
    FROM Months m
    LEFT JOIN (
        SELECT MONTH(created_at) AS month_num, COUNT(*) AS user_count
        FROM Users
        WHERE YEAR(created_at) = YEAR(GETDATE())
        GROUP BY MONTH(created_at)
    ) u ON u.month_num = m.month_num
    LEFT JOIN (
        SELECT MONTH(created_at) AS month_num, COUNT(*) AS activity_count
        FROM Activities
        WHERE YEAR(created_at) = YEAR(GETDATE())
        GROUP BY MONTH(created_at)
    ) a ON a.month_num = m.month_num
    ORDER BY m.month_num;
END
GO


/* =====================================================
   18. PROC HỖ TRỢ TOP INTERESTS
   ===================================================== */
IF OBJECT_ID('sp_AdminTopInterests', 'P') IS NOT NULL
BEGIN
    DROP PROCEDURE sp_AdminTopInterests;
END
GO

CREATE PROCEDURE sp_AdminTopInterests
AS
BEGIN
    SET NOCOUNT ON;

    SELECT TOP 10
        i.interest_id,
        i.name,
        COUNT(ui.user_id) AS total_users
    FROM Interests i
    LEFT JOIN UserInterests ui ON ui.interest_id = i.interest_id
    GROUP BY i.interest_id, i.name
    ORDER BY COUNT(ui.user_id) DESC, i.name ASC;
END
GO


/* =====================================================
   19. PROC HỖ TRỢ REPORT SUMMARY
   ===================================================== */
IF OBJECT_ID('sp_AdminReportSummary', 'P') IS NOT NULL
BEGIN
    DROP PROCEDURE sp_AdminReportSummary;
END
GO

CREATE PROCEDURE sp_AdminReportSummary
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        SUM(CASE WHEN status = 'pending' THEN 1 ELSE 0 END) AS pending_count,
        SUM(CASE WHEN status = 'resolved' THEN 1 ELSE 0 END) AS resolved_count,
        SUM(CASE WHEN status = 'dismissed' THEN 1 ELSE 0 END) AS dismissed_count
    FROM Reports;
END
GO


