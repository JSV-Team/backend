CREATE VIEW vw_AdminReportList
AS
SELECT
    r.report_id,
    r.reporter_id,
    reporter.username AS reporter_username,
    reporter.full_name AS reporter_full_name,

    r.reported_user_id,
    reported_user.username AS reported_user_username,
    reported_user.full_name AS reported_user_full_name,

    r.reported_activity_id,
    a.title AS reported_activity_title,

    r.reason,
    r.detail,
    r.severity,
    r.status,
    r.resolved_by,
    resolver.username AS resolved_by_username,
    r.resolved_at,
    r.handled_by,
    r.handled_at,
    r.created_at
FROM Reports r
LEFT JOIN Users reporter ON reporter.user_id = r.reporter_id
LEFT JOIN Users reported_user ON reported_user.user_id = r.reported_user_id
LEFT JOIN Activities a ON a.activity_id = r.reported_activity_id
LEFT JOIN Users resolver ON resolver.user_id = r.resolved_by;
GO


