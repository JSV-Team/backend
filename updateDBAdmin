/* =====================================================
   4. SỬA CHECK CONSTRAINT CHO ACTIVITIES.STATUS
   Hiện schema cũ ghi active/deleted, nhưng seed và admin cần:
   pending / approved / deleted
   ===================================================== */

IF EXISTS (
    SELECT 1
    FROM sys.check_constraints
    WHERE name = 'CHK_Activities_Status'
)
BEGIN
    ALTER TABLE Activities DROP CONSTRAINT CHK_Activities_Status;
END
GO

ALTER TABLE Activities
ADD CONSTRAINT CHK_Activities_Status
CHECK (status IN ('pending', 'approved', 'deleted'));
GO

-- Chuẩn hóa dữ liệu cũ nếu có
UPDATE Activities
SET status = 'approved'
WHERE status = 'active';
GO


