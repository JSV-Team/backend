/* =====================================================
   13. VIEW HỖ TRỢ ADMIN - USER LIST
   ===================================================== */
IF OBJECT_ID('vw_AdminUserList', 'V') IS NOT NULL
BEGIN
    DROP VIEW vw_AdminUserList;
END
GO

CREATE VIEW vw_AdminUserList
AS
SELECT
    u.user_id,
    u.username,
    u.email,
    u.full_name,
    u.avatar_url,
    u.location,
    u.reputation_score,
    u.status,
    u.ban_until,
    u.is_locked,
    u.role,
    u.created_at,
    u.gender,
    u.dob,
    COUNT(a.activity_id) AS total_activities
FROM Users u
LEFT JOIN Activities a ON a.creator_id = u.user_id
GROUP BY
    u.user_id,
    u.username,
    u.email,
    u.full_name,
    u.avatar_url,
    u.location,
    u.reputation_score,
    u.status,
    u.ban_until,
    u.is_locked,
    u.role,
    u.created_at,
    u.gender,
    u.dob;
GO


